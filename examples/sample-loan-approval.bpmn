<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions
  xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
  xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
  xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
  xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
  id="Definitions_1"
  targetNamespace="http://bpmn.io/schema/bpmn">

  <bpmn:process id="Process_loan_approval" name="贷款审批流程" isExecutable="true">

    <!-- 开始事件 -->
    <bpmn:startEvent id="StartEvent_1" name="客户提交贷款申请">
      <bpmn:outgoing>Flow_1</bpmn:outgoing>
    </bpmn:startEvent>

    <!-- 用户任务：初步审核 -->
    <bpmn:userTask id="Task_review" name="初步审核">
      <bpmn:incoming>Flow_1</bpmn:incoming>
      <bpmn:outgoing>Flow_2</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sequenceFlow id="Flow_1" sourceRef="StartEvent_1" targetRef="Task_review"/>

    <!-- 排他网关：金额判断 -->
    <bpmn:exclusiveGateway id="Gateway_amount" name="贷款金额">
      <bpmn:incoming>Flow_2</bpmn:incoming>
      <bpmn:outgoing>Flow_3_small</bpmn:outgoing>
      <bpmn:outgoing>Flow_4_large</bpmn:outgoing>
    </bpmn:exclusiveGateway>

    <bpmn:sequenceFlow id="Flow_2" sourceRef="Task_review" targetRef="Gateway_amount"/>

    <!-- 小额：部门经理审批 -->
    <bpmn:userTask id="Task_manager" name="部门经理审批">
      <bpmn:incoming>Flow_3_small</bpmn:incoming>
      <bpmn:outgoing>Flow_5</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sequenceFlow id="Flow_3_small" sourceRef="Gateway_amount" targetRef="Task_manager" name="金额&lt;50万"/>

    <!-- 大额：风控审核 -->
    <bpmn:userTask id="Task_risk" name="风控审核">
      <bpmn:incoming>Flow_4_large</bpmn:incoming>
      <bpmn:outgoing>Flow_6</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sequenceFlow id="Flow_4_large" sourceRef="Gateway_amount" targetRef="Task_risk" name="金额≥50万"/>

    <!-- 汇合后：行长审批 -->
    <bpmn:userTask id="Task_director" name="行长审批">
      <bpmn:incoming>Flow_5</bpmn:incoming>
      <bpmn:incoming>Flow_6</bpmn:incoming>
      <bpmn:outgoing>Flow_7</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sequenceFlow id="Flow_5" sourceRef="Task_manager" targetRef="Task_director"/>
    <bpmn:sequenceFlow id="Flow_6" sourceRef="Task_risk" targetRef="Task_director"/>

    <!-- 放款 -->
    <bpmn:userTask id="Task_disburse" name="放款处理">
      <bpmn:incoming>Flow_7</bpmn:incoming>
      <bpmn:outgoing>Flow_8</bpmn:outgoing>
    </bpmn:userTask>

    <bpmn:sequenceFlow id="Flow_7" sourceRef="Task_director" targetRef="Task_disburse"/>

    <!-- 结束事件 -->
    <bpmn:endEvent id="EndEvent_1" name="贷款完成">
      <bpmn:incoming>Flow_8</bpmn:incoming>
    </bpmn:endEvent>

    <bpmn:sequenceFlow id="Flow_8" sourceRef="Task_disburse" targetRef="EndEvent_1"/>

  </bpmn:process>

  <!-- Diagram 坐标信息（BPMNShape 中的节点位置与大小） -->
  <bpmndi:BPMNDiagram id="BPMNDiagram_1">
    <bpmndi:BPMNPlane id="BPMNPlane_1" bpmnElement="Process_loan_approval">

      <!-- 开始事件 -->
      <bpmndi:BPMNShape id="BPMNShape_StartEvent_1" bpmnElement="StartEvent_1">
        <dc:Bounds x="80" y="240" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="60" y="285" width="80" height="20"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- 初步审核 -->
      <bpmndi:BPMNShape id="BPMNShape_Task_review" bpmnElement="Task_review">
        <dc:Bounds x="180" y="220" width="120" height="60"/>
      </bpmndi:BPMNShape>

      <!-- 网关：金额判断 -->
      <bpmndi:BPMNShape id="BPMNShape_Gateway_amount" bpmnElement="Gateway_amount">
        <dc:Bounds x="380" y="230" width="50" height="50"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="360" y="290" width="100" height="20"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- 部门经理审批 -->
      <bpmndi:BPMNShape id="BPMNShape_Task_manager" bpmnElement="Task_manager">
        <dc:Bounds x="520" y="140" width="120" height="60"/>
      </bpmndi:BPMNShape>

      <!-- 风控审核 -->
      <bpmndi:BPMNShape id="BPMNShape_Task_risk" bpmnElement="Task_risk">
        <dc:Bounds x="520" y="320" width="120" height="60"/>
      </bpmndi:BPMNShape>

      <!-- 行长审批 -->
      <bpmndi:BPMNShape id="BPMNShape_Task_director" bpmnElement="Task_director">
        <dc:Bounds x="720" y="220" width="120" height="60"/>
      </bpmndi:BPMNShape>

      <!-- 放款处理 -->
      <bpmndi:BPMNShape id="BPMNShape_Task_disburse" bpmnElement="Task_disburse">
        <dc:Bounds x="920" y="220" width="120" height="60"/>
      </bpmndi:BPMNShape>

      <!-- 结束事件 -->
      <bpmndi:BPMNShape id="BPMNShape_EndEvent_1" bpmnElement="EndEvent_1">
        <dc:Bounds x="1120" y="240" width="36" height="36"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1100" y="285" width="80" height="20"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>

      <!-- ========== 连线坐标 ========== -->
      <bpmndi:BPMNEdge id="BPMNEdge_Flow_1" bpmnElement="Flow_1">
        <di:waypoint x="116" y="258"/>
        <di:waypoint x="180" y="250"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="BPMNEdge_Flow_2" bpmnElement="Flow_2">
        <di:waypoint x="300" y="250"/>
        <di:waypoint x="380" y="255"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="BPMNEdge_Flow_3_small" bpmnElement="Flow_3_small">
        <di:waypoint x="405" y="230"/>
        <di:waypoint x="405" y="170"/>
        <di:waypoint x="520" y="170"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="450" y="150" width="70" height="15"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="BPMNEdge_Flow_4_large" bpmnElement="Flow_4_large">
        <di:waypoint x="405" y="280"/>
        <di:waypoint x="405" y="350"/>
        <di:waypoint x="520" y="350"/>
        <bpmndi:BPMNLabel>
          <dc:Bounds x="450" y="360" width="70" height="15"/>
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="BPMNEdge_Flow_5" bpmnElement="Flow_5">
        <di:waypoint x="640" y="170"/>
        <di:waypoint x="780" y="170"/>
        <di:waypoint x="780" y="220"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="BPMNEdge_Flow_6" bpmnElement="Flow_6">
        <di:waypoint x="640" y="350"/>
        <di:waypoint x="780" y="350"/>
        <di:waypoint x="780" y="280"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="BPMNEdge_Flow_7" bpmnElement="Flow_7">
        <di:waypoint x="840" y="250"/>
        <di:waypoint x="920" y="250"/>
      </bpmndi:BPMNEdge>

      <bpmndi:BPMNEdge id="BPMNEdge_Flow_8" bpmnElement="Flow_8">
        <di:waypoint x="1040" y="250"/>
        <di:waypoint x="1120" y="258"/>
      </bpmndi:BPMNEdge>

    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>

</bpmn:definitions>